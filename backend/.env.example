GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
SECRET_KEY=your_secret_key_here
DATABASE_URL=sqlite:///./data/skylight.db

# Set this to the URL your Pi is accessed at so Google OAuth redirects correctly.
# Must match the redirect URI you registered in Google Cloud Console.
# Examples:
#   APP_URL=http://odysseus.local
#   APP_URL=http://192.168.1.42
APP_URL=http://localhost:8000
